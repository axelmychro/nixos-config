{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "PRTS",
  "palette": {
    "night": "#2e3440",
    "frost": "#8fbcbb",
    "peach": "#d08770",
    "snow": "#d8dee9",
    "closer": "p:snow"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:night",
          "foreground": "p:frost",
          "options": {
            "folder_icon": "\ue5fe",
            "home_icon": "~",
            "style": "folder"
          },
          "template": "\ue5fe {{ .Folder }}",
          "type": "path",
          "style": "plain"
        },
        {
          "background": "p:night",
          "foreground": "p:peach",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "template": " {{ .HEAD }}",

          "type": "git",
          "style": "plain"
        },
        {
          "background": "p:night",
          "foreground": "p:closer",
          "template": " 󰈺 ",
          "type": "text",
          "style": "plain"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true
}
